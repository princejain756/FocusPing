<section class="cta section">
  <div class="container cta__inner">
    <h2>Remind you when you can act.</h2>
    <p>FocusPing is coming to the App Store. Join the waitlist by starring the repo or following along.</p>
    <div class="cta__actions">
      <a href="https://github.com/princejain756/FocusPing" class="btn btn-primary" rel="noopener noreferrer" target="_blank">
        View on GitHub
      </a>
      <a href="/support" class="btn btn-ghost">Get support</a>
    </div>
  </div>
</section>

<style>
  .cta__inner {
    text-align: center;
    padding: 3.5rem 2rem;
    background: linear-gradient(135deg, rgba(237, 107, 46, 0.12), rgba(115, 97, 209, 0.08));
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .cta h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin: 0 0 1rem;
  }

  .cta p {
    color: var(--text-muted);
    max-width: 40ch;
    margin: 0 auto 1.75rem;
  }

  .cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }
</style>
