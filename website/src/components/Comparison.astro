---
---

<section class="compare section">
  <div class="container">
    <p class="eyebrow">Why FocusPing</p>
    <h2>Not a planner. A delivery gate.</h2>
    <div class="compare__wrap">
      <table class="compare-table">
        <thead>
          <tr>
            <th scope="col"></th>
            <th scope="col">Day planners</th>
            <th scope="col">FocusPing</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th scope="row">Delivery timing</th>
            <td>Fixed schedule</td>
            <td class="yes">When you can act</td>
          </tr>
          <tr>
            <th scope="row">During hyperfocus</th>
            <td class="no">Still notifies</td>
            <td class="yes">Holds in queue</td>
          </tr>
          <tr>
            <th scope="row">Missed tasks</th>
            <td class="no">Overdue / vanish</td>
            <td class="yes">Stay in queue</td>
          </tr>
          <tr>
            <th scope="row">Streaks & guilt</th>
            <td class="no">Common</td>
            <td class="yes">None by design</td>
          </tr>
          <tr>
            <th scope="row">Minute-by-minute plan</th>
            <td class="no">Required</td>
            <td class="yes">Not needed</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .compare h2 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    margin: 0 0 2rem;
  }

  .compare__wrap {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg-card);
  }
</style>
