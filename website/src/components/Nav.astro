---
const links = [
  { href: '#how', label: 'How it works' },
  { href: '#features', label: 'Features' },
  { href: '#screenshots', label: 'Screenshots' },
];
---

<header class="nav">
  <div class="container nav__inner">
    <a href="/" class="nav__brand" aria-label="FocusPing home">
      <img src="/app-icon.png" alt="" width="36" height="36" class="nav__logo" />
      <span>FocusPing</span>
    </a>
    <nav class="nav__links" aria-label="Primary">
      {links.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
      <a href="/privacy">Privacy</a>
    </nav>
    <a href="#download" class="btn btn-primary nav__cta">Get the app</a>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    inset: 0 0 auto;
    z-index: 100;
    height: var(--nav-height);
    background: rgba(12, 11, 15, 0.82);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    gap: 1rem;
  }

  .nav__brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--text);
    text-decoration: none;
  }

  .nav__logo {
    border-radius: 22%;
  }

  .nav__links {
    display: none;
    gap: 1.75rem;
  }

  .nav__links a {
    color: var(--text-muted);
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
  }

  .nav__links a:hover {
    color: var(--text);
  }

  .nav__cta {
    font-size: 0.9rem;
    padding: 0.6rem 1.1rem;
    min-height: 40px;
  }

  @media (min-width: 768px) {
    .nav__links {
      display: flex;
    }
  }
</style>
