---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  path?: string;
  ogType?: string;
}

const {
  title,
  description,
  path = '',
  ogType = 'website',
} = Astro.props;

const canonical = new URL(path, Astro.site);
const fullTitle = path === '/' || path === ''
  ? `${title} — Remind when you can act`
  : `${title} · FocusPing`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MobileApplication',
  name: 'FocusPing',
  operatingSystem: 'iOS',
  applicationCategory: 'ProductivityApplication',
  description,
  image: new URL('/app-icon.png', Astro.site).href,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#0c0b0f" />

    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site)} />
    <meta property="og:site_name" content="FocusPing" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og-image.png', Astro.site)} />

    <meta name="apple-mobile-web-app-title" content="FocusPing" />
    <link rel="apple-touch-icon" href="/app-icon.png" />
    <link rel="icon" type="image/png" href="/app-icon.png" />

    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />
  </body>
</html>
